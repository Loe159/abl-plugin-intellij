ADD TABLE "Customer"
  AREA "Schema Area"
  DUMP-NAME "customer"

ADD FIELD "CustNum" OF "Customer" AS integer
  LABEL "Cust Num"
  COLUMN-LABEL "Cust#"
  FORMAT "99999"
  INITIAL "0"

ADD FIELD "Name" OF "Customer" AS character
  LABEL "Name"
  FORMAT "x(40)"
  INITIAL ""

ADD FIELD "CreditLimit" OF "Customer" AS decimal
  LABEL "Credit Limit"
  FORMAT "->>,>>>,>>9.99"
  INITIAL "0"

ADD FIELD "Active" OF "Customer" AS logical
  LABEL "Active"
  FORMAT "yes/no"

ADD INDEX "pk_customer" ON "Customer"
  AREA "Schema Area"
  UNIQUE
  PRIMARY
  INDEX-FIELD "CustNum" ASCENDING

ADD TABLE "Order"
  AREA "Schema Area"
  DUMP-NAME "order"

ADD FIELD "OrderNum" OF "Order" AS integer
  LABEL "Order Num"
  FORMAT "99999"

ADD FIELD "CustNum" OF "Order" AS integer
  LABEL "Cust Num"
  FORMAT "99999"

ADD FIELD "OrderDate" OF "Order" AS date
  LABEL "Order Date"
  FORMAT "99/99/9999"

ADD FIELD "Amount" OF "Order" AS decimal
  LABEL "Amount"
  FORMAT "->>,>>9.99"

ADD INDEX "pk_order" ON "Order"
  AREA "Schema Area"
  UNIQUE
  PRIMARY
  INDEX-FIELD "OrderNum" ASCENDING
