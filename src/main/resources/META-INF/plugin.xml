<!-- ABL Language Support Plugin — plugin.xml -->
<idea-plugin>

    <id>com.ablls.abl-language-support</id>
    <name>ABL Language Support</name>
    <vendor email="contact@ablls.com" url="https://github.com/your-org/abl-intellij-plugin">
        ABL Language Support
    </vendor>
    <version>1.0.0</version>
    <idea-version since-build="232"/>

    <description><![CDATA[
        <b>ABL Language Support for IntelliJ IDEA</b><br/>
        <br/>
        Support complet du langage Progress OpenEdge ABL (Advanced Business Language) :<br/>
        <ul>
          <li>Coloration syntaxique — via le parser CABL (Riverside Software)</li>
          <li>Complétion de code (IntelliSense) — mots-clés + symboles du projet</li>
          <li>Navigation : Go to Definition</li>
          <li>Diagnostics en temps réel (erreurs de syntaxe CABL)</li>
          <li>Documentation hover (built-ins + symboles utilisateur)</li>
          <li>Lecture du fichier openedge-project.json</li>
        </ul>
        <br/>
        Extensions supportées : .p, .cls, .i, .w, .t
    ]]></description>

    <!-- ── Dépendances ──────────────────────────────────────────────────────── -->
    <depends>com.intellij.modules.platform</depends>

    <!-- ── Extension points ───────────────────────────────────────────────── -->
    <extensions defaultExtensionNs="com.intellij">

        <!-- ── Type de fichier ──────────────────────────────────────────────── -->
        <fileType
            name="ABL File"
            implementationClass="com.ablls.plugin.language.AblFileType"
            fieldName="INSTANCE"
            language="ABL"
            extensions="p;cls;i;w;t"/>

        <!-- ── Settings ─────────────────────────────────────────────────────── -->
        <projectConfigurable
            parentId="language"
            displayName="OpenEdge ABL"
            id="com.ablls.plugin.settings.openedge"
            implementationClass="com.ablls.plugin.project.AblProjectSettingsConfigurable"
            instance="true"/>

        <!-- ── Coloration syntaxique ────────────────────────────────────────── -->
        <lang.syntaxHighlighterFactory
            language="ABL"
            implementationClass="com.ablls.plugin.highlight.AblHighlighterFactory"/>

        <colorSettingsPage
            implementation="com.ablls.plugin.highlight.AblColorSettingsPage"/>

        <!-- ── Parser / PSI ─────────────────────────────────────────────────── -->
        <lang.parserDefinition
            language="ABL"
            implementationClass="com.ablls.plugin.parser.AblParserDefinition"/>

        <!-- ── Folding (DO...END, PROCEDURE...END, CLASS...END) ────────────── -->
        <lang.foldingBuilder
            language="ABL"
            implementationClass="com.ablls.plugin.highlight.AblFoldingBuilder"/>

        <!-- ── Commenter (/* */ et //) ─────────────────────────────────────── -->
        <lang.commenter
            language="ABL"
            implementationClass="com.ablls.plugin.highlight.AblCommenter"/>

        <!-- ── Structure view (outline du fichier) ──────────────────────────── -->
        <lang.psiStructureViewFactory
            language="ABL"
            implementationClass="com.ablls.plugin.structure.AblStructureViewFactory"/>

        <!-- ── Services projet ───────────────────────────────────────────────── -->
        <projectService
            serviceImplementation="com.ablls.plugin.core.AblProjectAnalysisService"/>

        <projectService
            serviceInterface="com.ablls.plugin.project.OpenEdgeProjectService"
            serviceImplementation="com.ablls.plugin.project.OpenEdgeProjectServiceImpl"/>

        <!-- ── Diagnostics : erreurs syntaxiques CABL ────────────────────────── -->
        <externalAnnotator
            language="ABL"
            implementationClass="com.ablls.plugin.annotator.AblAnnotator"/>

        <!-- ── Inspections (Best Practices & Linting) ────────────────────────── -->
        <localInspection language="ABL" groupPath="OpenEdge ABL" groupName="Best Practices"
                         displayName="Missing NO-UNDO modifier" shortName="AblMissingNoUndo"
                         enabledByDefault="true" level="WARNING"
                         implementationClass="com.ablls.plugin.inspections.AblNoUndoInspection"/>
        <localInspection language="ABL" groupPath="OpenEdge ABL" groupName="Best Practices"
                         displayName="Missing Lock mode on FIND" shortName="AblFindNoLock"
                         enabledByDefault="true" level="WARNING"
                         implementationClass="com.ablls.plugin.inspections.AblFindNoLockInspection"/>
        <localInspection language="ABL" groupPath="OpenEdge ABL" groupName="Best Practices"
                         displayName="NO-ERROR without error check" shortName="AblNoErrorWithoutCheck"
                         enabledByDefault="true" level="WARNING"
                         implementationClass="com.ablls.plugin.inspections.AblNoErrorWithoutCheckInspection"/>
        <localInspection language="ABL" groupPath="OpenEdge ABL" groupName="Best Practices"
                         displayName="Variable defined but never read" shortName="AblUnusedVariable"
                         enabledByDefault="true" level="WARNING"
                         implementationClass="com.ablls.plugin.inspections.AblUnusedVariableInspection"/>
        <localInspection language="ABL" groupPath="OpenEdge ABL" groupName="Best Practices"
                         displayName="Fortran-style comparison operator" shortName="AblFortranOperators"
                         enabledByDefault="true" level="WARNING"
                         implementationClass="com.ablls.plugin.inspections.AblFortranOperatorsInspection"/>
        <localInspection language="ABL" groupPath="OpenEdge ABL" groupName="Best Practices"
                         displayName="String concatenation in WHERE clause" shortName="AblStringConcatInWhere"
                         enabledByDefault="true" level="WARNING"
                         implementationClass="com.ablls.plugin.inspections.AblStringConcatInWhereInspection"/>
        <localInspection language="ABL" groupPath="OpenEdge ABL" groupName="Best Practices"
                         displayName="Empty or return-only CATCH block" shortName="AblEmptyCatch"
                         enabledByDefault="true" level="WARNING"
                         implementationClass="com.ablls.plugin.inspections.AblEmptyCatchInspection"/>
        <localInspection language="ABL" groupPath="OpenEdge ABL" groupName="Security"
                         displayName="Table reference without database prefix (multi-db)"
                         shortName="AblMissingSchemaPrefix"
                         enabledByDefault="true" level="WARNING"
                         implementationClass="com.ablls.plugin.inspections.AblMissingSchemaPrefixInspection"/>
        <localInspection language="ABL" groupPath="OpenEdge ABL" groupName="Best Practices"
                         displayName="High cognitive complexity (RSSW)"
                         shortName="AblCognitiveComplexity"
                         enabledByDefault="true" level="WEAK WARNING"
                         implementationClass="com.ablls.plugin.inspections.AblCognitiveComplexityInspection"/>
        <localInspection language="ABL" groupPath="OpenEdge ABL" groupName="Best Practices"
                         displayName="FIND FIRST/LAST without NO-ERROR" shortName="AblFindFirstNoError"
                         enabledByDefault="true" level="WARNING"
                         implementationClass="com.ablls.plugin.inspections.AblFindFirstNoErrorInspection"/>
        <localInspection language="ABL" groupPath="OpenEdge ABL" groupName="Best Practices"
                         displayName="Internal procedure or function never referenced in file"
                         shortName="AblDeadCode"
                         enabledByDefault="true" level="WEAK WARNING"
                         implementationClass="com.ablls.plugin.inspections.AblDeadCodeInspection"/>
        <localInspection language="ABL" groupPath="OpenEdge ABL" groupName="Best Practices"
                         displayName="Overly long procedure or function (&gt; 150 lines)"
                         shortName="AblProcedureLength"
                         enabledByDefault="true" level="WEAK WARNING"
                         implementationClass="com.ablls.plugin.inspections.AblProcedureLengthInspection"/>
        <localInspection language="ABL" groupPath="OpenEdge ABL" groupName="Best Practices"
                         displayName="LEAVE/NEXT without label in nested loop"
                         shortName="AblUnlabeledLoopControl"
                         enabledByDefault="true" level="WARNING"
                         implementationClass="com.ablls.plugin.inspections.AblUnlabeledLoopControlInspection"/>
        <localInspection language="ABL" groupPath="OpenEdge ABL" groupName="Database"
                         displayName="Table or field not found in loaded schema"
                         shortName="AblSchemaValidation"
                         enabledByDefault="true" level="WARNING"
                         implementationClass="com.ablls.plugin.inspections.AblSchemaValidationInspection"/>
        <localInspection language="ABL" groupPath="OpenEdge ABL" groupName="Best Practices"
                         displayName="INTEGER variable may overflow — consider INT64"
                         shortName="AblIntegerOverflow"
                         enabledByDefault="true" level="WEAK WARNING"
                         implementationClass="com.ablls.plugin.inspections.AblIntegerOverflowInspection"/>
        <localInspection language="ABL" groupPath="OpenEdge ABL" groupName="Best Practices"
                         displayName="High cyclomatic complexity (McCabe CC &gt; 10)"
                         shortName="AblCyclomaticComplexity"
                         enabledByDefault="true" level="WEAK WARNING"
                         implementationClass="com.ablls.plugin.inspections.AblCyclomaticComplexityInspection"/>
        <localInspection language="ABL" groupPath="OpenEdge ABL" groupName="Naming"
                         displayName="Variable name does not follow ABL naming conventions"
                         shortName="AblNamingConvention"
                         enabledByDefault="false" level="WEAK WARNING"
                         implementationClass="com.ablls.plugin.inspections.AblNamingConventionInspection"/>

        <!-- ── Avertissements compilateur ──────────────────────────────────────────── -->
        <externalAnnotator language="ABL"
                           implementationClass="com.ablls.plugin.annotator.AblCompilerWarningAnnotator"/>

        <!-- ── Couverture de code (profiler) ───────────────────────────────────── -->
        <projectService serviceImplementation="com.ablls.plugin.coverage.AblCoverageService"/>
        <toolWindow id="ABL Profiler" secondary="true" icon="/icons/abl-file.svg"
                    anchor="bottom" factoryClass="com.ablls.plugin.coverage.AblProfilerViewFactory"
                    doNotActivateOnStart="true"/>

        <!-- ── Tool windows ──────────────────────────────────────────────────────────── -->
        <toolWindow id="ABL Schema" secondary="true" icon="/icons/abl-file.svg"
                    anchor="right" factoryClass="com.ablls.plugin.db.AblSchemaExplorerFactory"
                    doNotActivateOnStart="true"/>
        <toolWindow id="ABL PROPATH" secondary="true" icon="/icons/abl-file.svg"
                    anchor="right" factoryClass="com.ablls.plugin.project.AblPropathExplorerFactory"
                    doNotActivateOnStart="true"/>
        <toolWindow id="ABL XREF" secondary="true" icon="/icons/abl-file.svg"
                    anchor="bottom" factoryClass="com.ablls.plugin.xref.XrefToolWindowFactory"/>
        <toolWindow id="ABL Duplicates" secondary="true" icon="/icons/abl-file.svg"
                    anchor="bottom" factoryClass="com.ablls.plugin.duplication.AblDuplicatesToolWindowFactory"/>

        <!-- ── Debug ──────────────────────────────────────────────────────────────────────── -->
        <configurationType implementation="com.ablls.plugin.debug.AblDebugConfigurationType"/>
        <xdebugger.breakpointType implementation="com.ablls.plugin.debug.AblLineBreakpointType"/>

        <!-- ── Program runners ─────────────────────────────────────────────────────────── -->
        <!--
             AblProgramRunner gère deux cas :
               1. "ABL Program" + Debug (si debugPort > 0)  → launch OE -debugport + auto-attach
               2. "ABL Remote Debug" + Debug                → attach à un OE déjà démarré
             Le mode Run simple est géré par DefaultProgramRunner (CommandLineState).
        -->
        <programRunner implementation="com.ablls.plugin.run.AblProgramRunner"/>

        <!-- ── Console filter ──────────────────────────────────────────────────────── -->
        <consoleFilterProvider implementation="com.ablls.plugin.run.AblConsoleFilterProvider"/>

        <!-- ── Complétion de code ─────────────────────────────────────────────── -->
        <completion.contributor
            language="ABL"
            implementationClass="com.ablls.plugin.completion.AblCompletionContributor"/>

        <!-- ── Live Templates (Snippets) ────────────────────────────────────── -->
        <defaultLiveTemplates file="liveTemplates/abl.xml"/>
        <liveTemplateContext implementation="com.ablls.plugin.completion.AblTemplateContextType"/>

        <!-- ── Auto-Casing (Formatage à la volée) ──────────────────────────── -->
        <typedHandler implementation="com.ablls.plugin.completion.AblAutoCaseTypedHandler" />

        <!-- ── Documentation hover ────────────────────────────────────────────── -->
        <lang.documentationProvider
            language="ABL"
            implementationClass="com.ablls.plugin.documentation.AblDocumentationProvider"/>

        <!-- ── Go to Definition ───────────────────────────────────────────────── -->
        <gotoDeclarationHandler
            implementationClass="com.ablls.plugin.navigation.AblGotoDeclarationHandler"/>

        <!-- ── Go to Symbol (Ctrl+Alt+Shift+N) ─────────────────────────────── -->
        <gotoSymbolContributor
            implementation="com.ablls.plugin.navigation.AblGotoSymbolContributor"/>

        <!-- ── Go to Class (Ctrl+N) ──────────────────────────────────────────── -->
        <gotoClassContributor
            implementation="com.ablls.plugin.navigation.AblGotoClassContributor"/>

        <!-- ── Find Usages ───────────────────────────────────────────────────── -->
        <lang.findUsagesProvider
            language="ABL"
            implementationClass="com.ablls.plugin.navigation.AblFindUsagesProvider"/>

        <!-- ── Rename ────────────────────────────────────────────────────────── -->
        <renameHandler
            implementation="com.ablls.plugin.refactor.AblRenameHandler"/>

        <!-- ── Hot Spots Inlay ──────────────────────────────────────────────── -->
        <codeInsight.inlayProvider
            language="ABL"
            implementationClass="com.ablls.plugin.coverage.AblHotSpotInlayProvider"/>

        <!-- ── Inlay Hints ──────────────────────────────────────────────────── -->
        <codeInsight.inlayProvider
            language="ABL"
            implementationClass="com.ablls.plugin.hints.AblTypeInlayHintsProvider"/>
        <codeInsight.inlayProvider
            language="ABL"
            implementationClass="com.ablls.plugin.hints.AblParameterInlayHintsProvider"/>

        <!-- ── Parameter Info (Ctrl+P) ──────────────────────────────────────── -->
        <codeInsight.parameterInfo
            language="ABL"
            implementationClass="com.ablls.plugin.completion.AblParameterInfoHandler"/>

        <!-- ── Postfix Completion ───────────────────────────────────────────── -->
        <codeInsight.template.postfixTemplateProvider
            language="ABL"
            implementationClass="com.ablls.plugin.completion.AblPostfixTemplateProvider"/>

        <!-- ── Code Formatter ───────────────────────────────────────────────── -->
        <lang.formatter
            language="ABL"
            implementationClass="com.ablls.plugin.highlight.AblFormattingModelBuilder"/>

        <!-- ── Code Style Settings (Settings → Editor → Code Style → OpenEdge ABL) ── -->
        <codeStyleSettingsProvider
            implementation="com.ablls.plugin.highlight.AblCodeStyleSettingsProvider"/>
        <langCodeStyleSettingsProvider
            implementation="com.ablls.plugin.highlight.AblLanguageCodeStyleSettingsProvider"/>

        <!-- ── Breadcrumb navigation ────────────────────────────────────────── -->
        <breadcrumbsInfoProvider
            implementation="com.ablls.plugin.navigation.AblBreadcrumbProvider"/>

        <!-- ── Spell Checking ───────────────────────────────────────────────── -->
        <spellchecker.support
            language="ABL"
            implementationClass="com.ablls.plugin.highlight.AblSpellcheckingStrategy"/>

        <!-- ── Overriding Methods Gutter ───────────────────────────────────── -->
        <codeInsight.lineMarkerProvider
            language="ABL"
            implementationClass="com.ablls.plugin.navigation.AblOverridingMethodsProvider"/>

        <!-- ── Coverage Gutter ──────────────────────────────────────────────── -->
        <codeInsight.lineMarkerProvider
            language="ABL"
            implementationClass="com.ablls.plugin.coverage.AblCoverageLineMarkerProvider"/>

        <!-- ── Gutter Icons (compile) ────────────────────────────────────────── -->
        <codeInsight.lineMarkerProvider
            language="ABL"
            implementationClass="com.ablls.plugin.run.AblCompileGutterIconProvider"/>
        <!--
             AblTestRunLineMarkerProvider (gutter @Test ABLUnit) désactivé :
             l'action de navigation était null → clic sans effet (UX trompeuse).
             Ré-activer quand un vrai runner ABLUnit (SMTRunnerConsoleProperties) sera implémenté.
        -->

        <!-- ── Surround With (Ctrl+Alt+T) ──────────────────────────────────── -->
        <lang.surroundDescriptor
            language="ABL"
            implementationClass="com.ablls.plugin.intentions.AblSurroundDescriptor"/>

        <!-- ── Type Hierarchy (Ctrl+H) ──────────────────────────────────────── -->
        <lang.typeHierarchyProvider
            language="ABL"
            implementationClass="com.ablls.plugin.navigation.AblTypeHierarchyProvider"/>

        <!-- ── Call Hierarchy (Ctrl+Alt+H) ──────────────────────────────────── -->
        <lang.callHierarchyProvider
            language="ABL"
            implementationClass="com.ablls.plugin.navigation.AblCallHierarchyProvider"/>

        <!-- ── Navigate to Super Class (Ctrl+U) ────────────────────────────── -->
        <codeInsight.gotoSuper
            language="ABL"
            implementationClass="com.ablls.plugin.navigation.AblSuperClassNavigator"/>

        <!-- ── Go to Related Symbol (Ctrl+Alt+Home) ──────────────────────── -->
        <gotoRelatedProvider
            implementation="com.ablls.plugin.navigation.AblGotoRelatedProvider"/>

        <!-- ── Safe Delete ───────────────────────────────────────────────────── -->
        <lang.refactoringSupport
            language="ABL"
            implementationClass="com.ablls.plugin.refactor.AblRefactoringSupportProvider"/>

        <!-- ── Intention Actions ─────────────────────────────────────────────── -->
        <intentionAction>
            <language>ABL</language>
            <className>com.ablls.plugin.intentions.AblAddNoUndoToAllIntention</className>
            <category>ABL Best Practices</category>
        </intentionAction>
        <intentionAction>
            <language>ABL</language>
            <className>com.ablls.plugin.intentions.AblOptimizeUsingsIntention</className>
            <category>ABL Imports</category>
        </intentionAction>
        <intentionAction>
            <language>ABL</language>
            <className>com.ablls.plugin.intentions.AblExtractProcedureIntention</className>
            <category>ABL Extract</category>
        </intentionAction>
        <intentionAction>
            <language>ABL</language>
            <className>com.ablls.plugin.intentions.AblIntroduceVariableIntention</className>
            <category>ABL Refactor</category>
        </intentionAction>
        <intentionAction>
            <language>ABL</language>
            <className>com.ablls.plugin.intentions.AblInlineVariableIntention</className>
            <category>ABL Refactor</category>
        </intentionAction>
        <intentionAction>
            <language>ABL</language>
            <className>com.ablls.plugin.intentions.AblChangeSignatureIntention</className>
            <category>ABL Change Signature</category>
        </intentionAction>
        <intentionAction>
            <language>ABL</language>
            <className>com.ablls.plugin.intentions.AblAddUsingIntention</className>
            <category>ABL USING</category>
        </intentionAction>

        <!-- ── Bracket Matcher ───────────────────────────────────────────────── -->
        <lang.bracketMatcher
            language="ABL"
            implementationClass="com.ablls.plugin.highlight.AblBracketMatcher"/>

        <!-- ── Project Wizard — File → New → Project → OpenEdge ABL ───────────── -->
        <moduleBuilder builderClass="com.ablls.plugin.project.AblModuleBuilder"/>

        <!-- ── Activité de démarrage : indexation du projet ──────────────────── -->
        <postStartupActivity
            implementation="com.ablls.plugin.startup.AblStartupActivity"/>

        <postStartupActivity
            implementation="com.ablls.plugin.project.AblProjectListener"/>

        <!-- ── Notification group ───────────────────────────────────────────── -->
        <notificationGroup
            id="ABL Language Support"
            displayType="BALLOON"/>

        <!-- ── Run configuration : lancer un .p directement ─────────────────── -->
        <configurationType
            implementation="com.ablls.plugin.run.AblRunConfigurationType"/>

        <!-- ── Run configuration producer ──────────────────────────────────── -->
        <!--
             Crée automatiquement une config "ABL Program" depuis le contexte
             (fichier .p/.cls/.w ouvert ou sélectionné) :
               - Active les boutons Run/Debug dans la barre d'outils de l'éditeur
               - Ajoute "Run <fichier>" dans le menu clic-droit
        -->
        <runConfigurationProducer
            implementation="com.ablls.plugin.run.AblRunConfigurationProducer"/>

    </extensions>

    <!-- ── Actions du menu ────────────────────────────────────────────────────── -->
    <actions>

        <action id="ABL.ReindexProject"
                class="com.ablls.plugin.actions.ReindexProjectAction"
                text="Re-index ABL Project"
                description="Relance l'indexation des symboles ABL du projet">
            <add-to-group group-id="ToolsMenu" anchor="last"/>
        </action>

        <action id="ABL.OpenProjectConfig"
                class="com.ablls.plugin.actions.OpenProjectConfigAction"
                text="Open openedge-project.json"
                description="Ouvre ou crée le fichier de configuration du projet ABL">
            <add-to-group group-id="ToolsMenu" anchor="last"/>
        </action>

        <action id="ABL.ShowXref"
                class="com.ablls.plugin.xref.ShowXrefAction"
                text="Show ABL XREF"
                description="Opens the ABL XREF tool window">
            <add-to-group group-id="ToolsMenu" anchor="last"/>
        </action>

        <action id="ABL.FindDuplicates"
                class="com.ablls.plugin.duplication.FindAblDuplicatesAction"
                text="Find ABL Duplicates"
                description="Detect duplicated ABL code blocks">
            <add-to-group group-id="ToolsMenu" anchor="last"/>
        </action>

        <action id="ABL.LoadCoverage"
                class="com.ablls.plugin.coverage.LoadCoverageAction"
                text="Load ABL Coverage (.prof)"
                description="Load an OpenEdge profiler file to display code coverage">
            <add-to-group group-id="ToolsMenu" anchor="last"/>
        </action>

        <!-- ── Refactoring ABL dans le menu Refactor ───────────────────────── -->
        <action id="ABL.ExtractProcedure"
                class="com.ablls.plugin.refactor.AblExtractProcedureAction"
                text="Extract ABL PROCEDURE"
                description="Extract selected code into a new PROCEDURE">
            <add-to-group group-id="RefactoringMenu" anchor="last"/>
        </action>
        <action id="ABL.IntroduceVariable"
                class="com.ablls.plugin.refactor.AblIntroduceVariableAction"
                text="Introduce ABL Variable"
                description="Introduce a DEFINE VARIABLE for the selected expression">
            <add-to-group group-id="RefactoringMenu" anchor="last"/>
        </action>
        <action id="ABL.InlineVariable"
                class="com.ablls.plugin.refactor.AblInlineVariableAction"
                text="Inline ABL Variable"
                description="Replace variable usages with its initializer value">
            <add-to-group group-id="RefactoringMenu" anchor="last"/>
        </action>
        <action id="ABL.ChangeSignature"
                class="com.ablls.plugin.refactor.AblChangeSignatureAction"
                text="Change ABL Signature"
                description="Add a parameter to the current PROCEDURE or FUNCTION">
            <add-to-group group-id="RefactoringMenu" anchor="last"/>
        </action>

        <action id="ABL.SafeDelete"
                class="com.ablls.plugin.refactor.AblSafeDeleteAction"
                text="ABL Safe Delete"
                description="Delete symbol after checking for usages in project">
            <keyboard-shortcut keymap="$default" first-keystroke="alt DELETE"/>
            <add-to-group group-id="RefactoringMenu" anchor="last"/>
        </action>

    </actions>

    <!-- ── Listeners ───────────────────────────────────────────────────────── -->
    <applicationListeners>
    </applicationListeners>

    <projectListeners>
        <listener class="com.ablls.plugin.annotator.AblWarningFileListener"
                  topic="com.intellij.openapi.vfs.newvfs.BulkFileListener"/>
    </projectListeners>

</idea-plugin>
